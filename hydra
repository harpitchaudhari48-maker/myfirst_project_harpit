    "import os, sys, time, socket, subprocess\n",
    "from pathlib import Path\n",
    "import torch\n",
    "\n",
    "def find_project_root() -> Path:\n",
    "    \"\"\"Walk up from the notebook's working directory looking for common\n",
    "    project markers. Falls back to the current working directory.\"\"\"\n",
    "    cwd = Path.cwd().resolve()\n",
    "    markers = [\"data.yaml\", \"dataset\", \"datasets\", \"images\", \".git\", \"runs\"]\n",
    "    candidates = [cwd] + list(cwd.parents)\n",
    "    for d in candidates[:6]:\n",
    "        for m in markers:\n",
    "            if (d / m).exists():\n",
    "                return d\n",
    "    return cwd\n",
    "\n",
    "PROJECT_ROOT = find_project_root()\n",
    "os.chdir(PROJECT_ROOT)\n",
    "print(f\"Project root : {PROJECT_ROOT}\")\n",
    "\n",
    "# --- GPU detection: makes no assumption about count or index. Works on 0, 1, or N GPUs. ---\n",
    "NUM_GPUS = torch.cuda.device_count() if torch.cuda.is_available() else 0\n",
    "\n",
    "if NUM_GPUS > 1:\n",
    "    DEVICE = \",\".join(str(i) for i in range(NUM_GPUS))   # e.g. \"0,1,2,3\" -> Ultralytics multi-GPU DDP\n",
    "    print(f\"{NUM_GPUS} GPUs detected - training will use all of them (device=\\\"{DEVICE}\\\")\")\n",
    "    for i in range(NUM_GPUS):\n",
    "        props = torch.cuda.get_device_properties(i)\n",
    "        print(f\"  GPU {i}: {torch.cuda.get_device_name(i)}  ({props.total_memory / 1e9:.1f} GB)\")\n",
    "elif NUM_GPUS == 1:\n",
    "    DEVICE = \"0\"\n",
    "    props = torch.cuda.get_device_properties(0)\n",
    "    print(f\"1 GPU detected: {torch.cuda.get_device_name(0)}  ({props.total_memory / 1e9:.1f} GB)\")\n",
    "elif getattr(torch.backends, \"mps\", None) is not None and torch.backends.mps.is_available():\n",
    "    DEVICE = \"mps\"\n",
    "    print(\"No CUDA GPU found - using Apple Silicon (MPS)\")\n",
    "else:\n",
    "    DEVICE = \"cpu\"\n",
