ge.open(uploaded_file).convert(\"RGB\")\n\n    col1, col2 = st.columns(2)\n    with col1:\n        st.subheader(\"Original\")\n        st.image(image, use_container_width=True)\n\n    with st.spinner(\"Running detection...\"):\n        results = model.predict(np.array(image), conf=conf_threshold, device=INFER_DEVICE, verbose=False)\n    result = results[0]\n    annotated = result.plot()[:, :, ::-1]  # BGR -> RGB\n\n    with col2:\n        st.subheader(\"Detections\")\n        st.image(annotated, use_container_width=True)\n\n    boxes = result.boxes\n    if boxes is not None and len(boxes) > 0:\n        st.subheader(f\"Detected objects ({len(boxes)})\")\n        rows = []\n        for b in boxes:\n            cls_id = int(b.cls[0])\n            x1, y1, x2, y2 = [round(v, 1) for v in b.xyxy[0].tolist()]\n            rows.append(\n                {\n                    \"class\": model.names[cls_id],\n                    \"confidence\": round(float(b.conf[0]), 3),\n                    \"x1\": x1, \"y1\": y1, \"x2\": x2, \"y2\": y2,\n                }\n            )\n        st.table(rows)\n    else:\n        st.info(\"No objects detected above this confidence threshold — try lowering the slider.\")\nelse:\n    st.info(\"Upload an image to run detection.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-19T09:38:56.790372Z","iopub.execute_input":"2026-07-19T09:38:56.791322Z","iopub.status.idle":"2026-07-19T09:38:56.797466Z","shell.execute_reply.started":"2026-07-19T09:38:56.791287Z","shell.execute_reply":"2026-07-19T09:38:56.79665Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"from ultralytics import YOLO\nfrom pathlib import Path\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as patches\nfrom PIL import Image\nimport numpy as np\n\nmodel = YOLO(\"/kaggle/working/runs/train_exp/weights/best.pt\")\ntest_dir = Path(\"/kaggle/input/datasets/sshikamaru/car-object-detection/data/testing_images\")\n\n# ── Run on fi