    "%%writefile app.py\n",
    "import streamlit as st\n",
    "from ultralytics import YOLO\n",
    "from PIL import Image\n",
    "import numpy as np\n",
    "import torch\n",
    "import yaml\n",
    "from pathlib import Path\n",
    "\n",
    "st.set_page_config(page_title=\"Object Detector\", layout=\"wide\")\n",
    "\n",
    "\n",
    "@st.cache_resource\n",
    "def load_model():\n",
    "    config_path = Path(__file__).parent / \"app_config.yaml\"\n",
    "    with open(config_path) as f:\n",
    "        cfg = yaml.safe_load(f)\n",
    "    return YOLO(cfg[\"weights_path\"])\n",
    "\n",
    "\n",
    "model = load_model()\n",
    "\n",
    "st.title(\"Object Detection\")\n",
    "st.caption(f\"Classes: {', '.join(model.names.values())}\")\n",
    "\n",
    "# --- Auto-detect inference device(s); no assumption about GPU count ---\n",
    "gpu_count = torch.cuda.device_count() if torch.cuda.is_available() else 0\n",
    "if gpu_count > 1:\n",
    "    gpu_labels = [torch.cuda.get_device_name(i) for i in range(gpu_count)]\n",
    "    choice = st.sidebar.selectbox(\"Inference GPU\", range(gpu_count), format_func=lambda i: f\"GPU {i}: {gpu_labels[i]}\")\n",
    "    INFER_DEVICE = choice\n",
    "elif gpu_count == 1:\n",
    "    INFER_DEVICE = 0\n",
    "    st.sidebar.caption(f\"Running on GPU: {torch.cuda.get_device_name(0)}\")\n",
    "elif getattr(torch.backends, \"mps\", None) is not None and torch.backends.mps.is_available():\n",
    "    INFER_DEVICE = \"mps\"\n",
    "    st.sidebar.caption(\"Running on Apple Silicon (MPS)\")\n",
    "else:\n",
    "    INFER_DEVICE = \"cpu\"\n",
    "    st.sidebar.caption(\"Running on CPU\")\n",
    "\n",
    "conf_threshold = st.sidebar.slider(\"Confidence threshold\", 0.0, 1.0, 0.25, 0.01)\n",
    "st.sidebar.caption(\"Lower = more (and less certain) detections\")\n",
    "\n",
    "uploaded_file = st.file_uploader(\"Upload an image\", type=[\"jpg\", \"jpeg\", \"png\", \"bmp\"])\n",
    "\n",
    "if uploaded_file is not None:\n",
    "    image = Image.open(uploaded_file).convert(\"RGB\")\n",
    "\n",
    "    col1, col2 = st.columns(2)\n",
    "    with col1:\n",
    "        st.subheader(\"Original\")\n",
    "        st.image(image, use_container_width=True)\n",
    "\n",
    "    with st.spinner(\"Running detection...\"):\n",
    "        results = model.predict(np.array(image), conf=conf_threshold, device=INFER_DEVICE, verbose=False)\n",
    "    result = results[0]\n",
    "    annotated = result.plot()[:, :, ::-1]  # BGR -> RGB\n",
    "\n",
    "    with col2:\n",
    "        st.subheader(\"Detections\")\n",
    "        st.image(annotated, use_container_width=True)\n",
    "\n",
    "    boxes = result.boxes\n",
    "    if boxes is not None and len(boxes) > 0:\n",
    "        st.subheader(f\"Detected objects ({len(boxes)})\")\n",
    "        rows = []\n",
    "        for b in boxes:\n",
    "            cls_id = int(b.cls[0])\n",
    "            x1, y1, x2, y2 = [round(v, 1) for v in b.xyxy[0].tolist()]\n",
    "            rows.append(\n",
    "                {\n",
    "                    \"class\": model.names[cls_id],\n",
    "                    \"confidence\": round(float(b.conf[0]), 3),\n",
    "                    \"x1\": x1, \"y1\": y1, \"x2\": x2, \"y2\": y2,\n",
    "                }\n",
    "            )\n",
    "        st.table(rows)\n",
    "    else:\n",
    "        st.info(\"No objects detected above this confidence threshold — try lowering the slider.\")\n",
    "else:\n",
    "    st.info(\"Upload an image to run detection.\")\n"
