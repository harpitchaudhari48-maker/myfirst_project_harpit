    "# ═══ RESCUE CELL — runs INSTEAD of Cells 3 & 4 ═══════════════════════════\n",
    "import os, yaml, shutil, random, math, pandas as pd\n",
    "from pathlib import Path\n",
    "from PIL import Image\n",
    "\n",
    "CSV_PATH   = Path(\"/kaggle/input/datasets/sshikamaru/car-object-detection/data/train_solution_bounding_boxes (1).csv\")\n",
    "IMAGES_DIR = Path(\"/kaggle/input/datasets/sshikamaru/car-object-detection/data/training_images\")\n",
    "YOLO_DIR   = Path(\"/kaggle/working/yolo_dataset\")\n",
    "\n",
    "assert CSV_PATH.exists(),   f\"CSV not found: {CSV_PATH}\"\n",
    "assert IMAGES_DIR.exists(), f\"Images dir not found: {IMAGES_DIR}\"\n",
    "\n",
    "cached_yaml = YOLO_DIR / \"data.yaml\"\n",
    "if cached_yaml.exists():\n",
    "    print(f\"✓ Using cached YOLO dataset: {YOLO_DIR}\")\n",
    "    DATA_YAML = cached_yaml\n",
    "else:\n",
    "    print(\"Converting CSV → YOLO (first run, ~1 min) ...\")\n",
    "    df = pd.read_csv(CSV_PATH)\n",
    "    df.columns = [c.lower().strip() for c in df.columns]\n",
    "\n",
    "    IMG_EXTS  = {\".jpg\",\".jpeg\",\".png\",\".bmp\",\".webp\"}\n",
    "    available = {f.name: f for f in IMAGES_DIR.iterdir() if f.suffix.lower() in IMG_EXTS}\n",
    "    all_names = df[\"image\"].astype(str).unique().tolist()\n",
    "    matched   = [n for n in all_names if n in available]\n",
    "    print(f\"  Images in CSV: {len(all_names)} | matched on disk: {len(matched)}\")\n",
    "\n",
    "    random.seed(42); random.shuffle(matched)\n",
    "    val_set = set(matched[:max(1, math.ceil(len(matched)*0.15))])\n",
    "\n",
    "    for split in [\"train\",\"val\"]:\n",
    "        (YOLO_DIR/\"images\"/split).mkdir(parents=True, exist_ok=True)\n",
    "        (YOLO_DIR/\"labels\"/split).mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    for img_name, group in df.groupby(\"image\"):\n",
    "        img_name = str(img_name)\n",
    "        if img_name not in available: continue\n",
    "        split   = \"val\" if img_name in val_set else \"train\"\n",
    "        src     = available[img_name]\n",
    "        dst_img = YOLO_DIR/\"images\"/split/img_name\n",
    "        dst_lbl = YOLO_DIR/\"labels\"/split/(Path(img_name).stem+\".txt\")\n",
    "        if not dst_img.exists():\n",
    "            try:    dst_img.symlink_to(src.resolve())\n",
    "            except: shutil.copy2(src, dst_img)\n",
    "        with Image.open(src) as im: W, H = im.size\n",
    "        lines = []\n",
    "        for _, row in group.iterrows():\n",
    "            x1,y1,x2,y2 = float(row[\"xmin\"]),float(row[\"ymin\"]),float(row[\"xmax\"]),float(row[\"ymax\"])\n",
    "            x1,x2 = max(0,min(x1,W)), max(0,min(x2,W))\n",
    "            y1,y2 = max(0,min(y1,H)), max(0,min(y2,H))\n",
    "            if x2<=x1 or y2<=y1: continue\n",
    "            cx=(x1+x2)/2/W; cy=(y1+y2)/2/H; bw=(x2-x1)/W; bh=(y2-y1)/H\n",
    "            lines.append(f\"0 {cx:.6f} {cy:.6f} {bw:.6f} {bh:.6f}\")\n",
    "        dst_lbl.write_text(\"\\n\".join(lines))\n",
    "\n",
    "    data = {\"train\":str(YOLO_DIR/\"images\"/\"train\"), \"val\":str(YOLO_DIR/\"images\"/\"val\"), \"nc\":1, \"names\":[\"car\"]}\n",
    "    DATA_YAML = YOLO_DIR/\"data.yaml\"\n",
    "    yaml.dump(data, open(DATA_YAML,\"w\"), sort_keys=False)\n",
    "    print(\"✓ Conversion done\")\n",
    "\n",
    "print(f\"\\nDATA_YAML = {DATA_YAML}\")\n",
    "print(open(DATA_YAML).read())\n",
    "_t = Path(yaml.safe_load(open(DATA_YAML))[\"train\"])\n",
    "NUM_TRAIN_IMAGES = sum(1 for p in _t.rglob(\"*\") if p.suffix.lower() in {\".jpg\",\".jpeg\",\".png\"})\n",
    "print(f\"Training images: {NUM_TRAIN_IMAGES}\")\n",
    "# ═══════════════════════════════════════════════════════════════════════════\n"
