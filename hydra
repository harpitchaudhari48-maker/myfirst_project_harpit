{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":3866417}],"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"# Auto Object Detection Pipeline (YOLOv8)\n\nThis notebook is fully self-configuring — nothing is hardcoded to a specific\nmachine, GPU count, or dataset:\n\n1. **Detects the project directory** it's running in\n2. **Detects every available GPU** — runs correctly on 0, 1, or N GPUs\n   (CUDA, any count) with automatic multi-GPU training, falls back to\n   Apple MPS or CPU if no CUDA GPU is present\n3. **Auto-locates your dataset** (existing `data.yaml`, or a standard\n   `images/` + `labels/` YOLO folder layout) and builds `data.yaml` if missing\n4. **Auto-selects model size, epoch budget, and batch size** from the\n   detected hardware (GPU memory) and dataset size — no fixed numbers to edit\n5. **Trains** a YOLOv8 model on the dataset, using all detected GPUs\n6. **Saves and reloads** the best weights to confirm they load cleanly\n7. **Launches a Streamlit app** with an image upload button, live bounding\n   box detection, a confidence threshold slider, and a GPU picker if more\n   than one GPU is available at inference time\n\n### Before you run\nPlace your dataset anywhere under the project folder using one of these layouts:\n\n```\ndataset/\n├── data.yaml            # optional - if present, it's used as-is\n├── images/\n│   ├── train/\n│   └── val/\n└── labels/\n    ├── train/\n    └── val/\n```\n\nIf you don't have a `classes.txt` / `data.yaml`, the notebook will infer the\nnumber of classes from your label files and name them `class0, class1, ...`\n— rename `names:` in the generated `data.yaml` afterwards if you want real\nclass names.\n\nRun the cells top to bottom.\n","metadata":{}},{"cell_type":"markdown","source":"## 1. Install dependencies","metadata":{}},{"cell_type":"code","source":"%pip install -q ultralytics streamlit opencv-python-headless pillow pyyaml pandas\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T15:47:23.726781Z","iopub.execute_input":"2026-07-20T15:47:23.726975Z","iopub.status.idle":"2026-07-20T15:47:31.930778Z","shell.execute_reply.started":"2026-07-20T15:47:23.726955Z","shell.execute_reply":"2026-07-20T15:47:31.929668Z"}},"outputs":[{"name":"stdout","text":"\u001b[2K     \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m42.2/42.2 kB\u001b[0m \u001b[31m1.7 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m1.4/1.4 MB\u001b[0m \u001b[31m22.4 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0ma \u001b[36m0:00:01\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m10.3/10.3 MB\u001b[0m \u001b[31m81.9 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m:00:01\u001b[0m0:01\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m11.4/11.4 MB\u001b[0m \u001b[31m94.8 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m:00:01\u001b[0m0:01\u001b[0m\n\u001b[?25hNote: you may need to restart the kernel to use updated packages.\n","output_type":"stream"}],"execution_count":1},{"cell_type":"markdown","source":"## 2. Auto-detect project root and every available GPU","metadata":{}},{"cell_type":"code","source":"import os, sys, time, socket, subprocess\nfrom pathlib import Path\nimport torch\n\ndef find_project_root() -> Path:\n    \"\"\"Walk up from the notebook's working directory looking for common\n    project markers. Falls back to the current working directory.\"\"\"\n    cwd = Path.cwd().resolve()\n    markers = [\"data.yaml\", \"dataset\", \"datasets\", \"images\", \".git\", \"runs\"]\n    candidates = [cwd] + list(cwd.parents)\n    for d in candidates[:6]:\n        for m in markers:\n            if (d / m).exists():\n                return d\n    return cwd\n\nPROJECT_ROOT = find_project_root()\nos.chdir(PROJECT_ROOT)\nprint(f\"Project root : {PROJECT_ROOT}\")\n\n# --- GPU detection: makes no assumption about count or index. Works on 0, 1, or N GPUs. ---\nNUM_GPUS = torch.cuda.device_count() if torch.cuda.is_available() else 0\n\nif NUM_GPUS > 1:\n    DEVICE = \",\".join(str(i) for i in range(NUM_GPUS))   # e.g. \"0,1,2,3\" -> Ultralytics multi-GPU DDP\n    print(f\"{NUM_GPUS} GPUs detected - training will use all of them (device=\\\"{DEVICE}\\\")\")\n    for i in range(NUM_GPUS):\n        props = torch.cuda.get_device_properties(i)\n        print(f\"  GPU {i}: {torch.cuda.get_device_name(i)}  ({props.total_memory / 1e9:.1f} GB)\")\nelif NUM_GPUS == 1:\n    DEVICE = \"0\"\n    props = torch.cuda.get_device_properties(0)\n    print(f\"1 GPU detected: {torch.cuda.get_device_name(0)}  ({props.total_memory / 1e9:.1f} GB)\")\nelif getattr(torch.backends, \"mps\", None) is not None and torch.backends.mps.is_available():\n    DEVICE = \"mps\"\n    print(\"No CUDA GPU found - using Apple Silicon (MPS)\")\nelse:\n    DEVICE = \"cpu\"\n    print(\"No GPU found - falling back to CPU (training will be slower)\")\n\nTOTAL_VRAM_GB = (\n    sum(torch.cuda.get_device_properties(i).total_memory for i in range(NUM_GPUS)) / 1e9\n    if NUM_GPUS else 0\n)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T15:48:11.685128Z","iopub.execute_input":"2026-07-20T15:48:11.685729Z","iopub.status.idle":"2026-07-20T15:48:15.761348Z","shell.execute_reply.started":"2026-07-20T15:48:11.685691Z","shell.execute_reply":"2026-07-20T15:48:15.76042Z"}},"outputs":[{"name":"stdout","text":"Project root : /kaggle/working\n2 GPUs detected - training will use all of them (device=\"0,1\")\n  GPU 0: Tesla T4  (15.6 GB)\n  GPU 1: Tesla T4  (15.6 GB)\n","output_type":"stream"}],"execution_count":2},{"cell_type":"markdown","source":"## 4. Build (or load) `data.yaml`","metadata":{}},{"cell_type":"code","source":"# ═══ RESCUE CELL — runs INSTEAD of Cells 3 & 4 ═══════════════════════════\nimport os, yaml, shutil, random, math, pandas as pd\nfrom pathlib import Path\nfrom PIL import Image\n\nCSV_PATH   = Path(\"/kaggle/input/datasets/sshikamaru/car-object-detection/data/train_solution_bounding_boxes (1).csv\")\nIMAGES_DIR = Path(\"/kaggle/input/datasets/sshikamaru/car-object-detection/data/training_images\")\nYOLO_DIR   = Path(\"/kaggle/working/yolo_dataset\")\n\nassert CSV_PATH.exists(),   f\"CSV not found: {CSV_PATH}\"\nassert IMAGES_DIR.exists(), f\"Images dir not found: {IMAGES_DIR}\"\n\ncached_yaml = YOLO_DIR / \"data.yaml\"\nif cached_yaml.exists():\n    print(f\"✓ Using cached YOLO dataset: {YOLO_DIR}\")\n    DATA_YAML = cached_yaml\nelse:\n    print(\"Converting CSV → YOLO (first run, ~1 min) ...\")\n    df = pd.read_csv(CSV_PATH)\n    df.columns = [c.lower().strip() for c in df.columns]\n\n    IMG_EXTS  = {\".jpg\",\".jpeg\",\".png\",\".bmp\",\".webp\"}\n    available = {f.name: f for f in IMAGES_DIR.iterdir() if f.suffix.lower() in IMG_EXTS}\n    all_names = df[\"image\"].astype(str).unique().tolist()\n    matched   = [n for n in all_names if n in available]\n    print(f\"  Images in CSV: {len(all_names)} | matched on disk: {len(matched)}\")\n\n    random.seed(42); random.shuffle(matched)\n    val_set = set(matched[:max(1, math.ceil(len(matched)*0.15))])\n\n    for split in [\"train\",\"val\"]:\n        (YOLO_DIR/\"images\"/split).mkdir(parents=True, exist_ok=True)\n        (YOLO_DIR/\"labels\"/split).mkdir(parents=True, exist_ok=True)\n\n    for img_name, group in df.groupby(\"image\"):\n        img_name = str(img_name)\n        if img_name not in available: continue\n        split   = \"val\" if img_name in val_set else \"train\"\n        src     = available[img_name]\n        dst_img = YOLO_DIR/\"images\"/split/img_name\n        dst_lbl = YOLO_DIR/\"labels\"/split/(Path(img_name).stem+\".txt\")\n        if not dst_img.exists():\n            try:    dst_img.symlink_to(src.resolve())\n            except: shutil.copy2(src, dst_img)\n        with Image.open(src) as im: W, H = im.size\n        lines = []\n        for _, row in group.iterrows():\n            x1,y1,x2,y2 = float(row[\"xmin\"]),float(row[\"ymin\"]),float(row[\"xmax\"]),float(row[\"ymax\"])\n            x1,x2 = max(0,min(x1,W)), max(0,min(x2,W))\n            y1,y2 = max(0,min(y1,H)), max(0,min(y2,H))\n            if x2<=x1 or y2<=y1: continue\n            cx=(x1+x2)/2/W; cy=(y1+y2)/2/H; bw=(x2-x1)/W; bh=(y2-y1)/H\n            lines.append(f\"0 {cx:.6f} {cy:.6f} {bw:.6f} {bh:.6f}\")\n        dst_lbl.write_text(\"\\n\".join(lines))\n\n    data = {\"train\":str(YOLO_DIR/\"images\"/\"train\"), \"val\":str(YOLO_DIR/\"images\"/\"val\"), \"nc\":1, \"names\":[\"car\"]}\n    DATA_YAML = YOLO_DIR/\"data.yaml\"\n    yaml.dump(data, open(DATA_YAML,\"w\"), sort_keys=False)\n    print(\"✓ Conversion done\")\n\nprint(f\"\\nDATA_YAML = {DATA_YAML}\")\nprint(open(DATA_YAML).read())\n_t = Path(yaml.safe_load(open(DATA_YAML))[\"train\"])\nNUM_TRAIN_IMAGES = sum(1 for p in _t.rglob(\"*\") if p.suffix.lower() in {\".jpg\",\".jpeg\",\".png\"})\nprint(f\"Training images: {NUM_TRAIN_IMAGES}\")\n# ═══════════════════════════════════════════════════════════════════════════\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T15:52:55.190335Z","iopub.execute_input":"2026-07-20T15:52:55.191129Z","iopub.status.idle":"2026-07-20T15:52:55.207971Z","shell.execute_reply.started":"2026-07-20T15:52:55.1911Z","shell.execute_reply":"2026-07-20T15:52:55.207273Z"}},"outputs":[{"name":"stdout","text":"✓ Using cached YOLO dataset: /kaggle/working/yolo_dataset\n\nDATA_YAML = /kaggle/working/yolo_dataset/data.yaml\ntrain: /kaggle/working/yolo_dataset/images/train\nval: /kaggle/working/yolo_dataset/images/val\nnc: 1\nnames:\n- car\n\nTraining images: 301\n","output_type":"stream"}],"execution_count":5},{"cell_type":"markdown","source":"## 5. Train\n\nNothing here is hardcoded — model size, epoch budget, and batch size are all\nderived from what was detected above (GPU count/memory, dataset size), so\nthis cell runs as-is on a laptop CPU, a single GPU, or a multi-GPU box\nwithout editing anything. You can still override any of `MODEL_ARCH`,\n`EPOCHS`, `IMG_SIZE`, or `BATCH` manually if you want specific values.\n","metadata":{}},{"cell_type":"code","source":"from ultralytics import YOLO\n\n# --- Auto-select model size from GPU memory available per device ---\nper_gpu_vram = (TOTAL_VRAM_GB / NUM_GPUS) if NUM_GPUS else 0\nif per_gpu_vram >= 16:\n    MODEL_ARCH = \"yolov8l.pt\"\nelif per_gpu_vram >= 8:\n    MODEL_ARCH = \"yolov8m.pt\"\nelif per_gpu_vram >= 4:\n    MODEL_ARCH = \"yolov8s.pt\"\nelse:\n    MODEL_ARCH = \"yolov8n.pt\"   # safest default for CPU / MPS / low-VRAM GPUs\n\n# --- Auto-select epoch budget from dataset size (smaller dataset -> more epochs) ---\nif NUM_TRAIN_IMAGES < 1000:\n    EPOCHS = 100\nelif NUM_TRAIN_IMAGES < 5000:\n    EPOCHS = 150\nelif NUM_TRAIN_IMAGES < 20000:\n    EPOCHS = 100\nelse:\n    EPOCHS = 50\n\nIMG_SIZE = 640\nWORKERS = os.cpu_count() or 4\n\n# --- Auto-select batch size ---\n# Ultralytics AutoBatch (batch=-1) picks the largest batch that fits in memory,\n# but it only supports a single device. With multiple GPUs we estimate a safe\n# per-GPU batch from measured VRAM and scale it by the number of GPUs instead.\nif NUM_GPUS > 1:\n    approx_model_gb = {\"yolov8n.pt\": 2, \"yolov8s.pt\": 3, \"yolov8m.pt\": 5, \"yolov8l.pt\": 7, \"yolov8x.pt\": 9}\n    per_gpu_batch = max(4, int((per_gpu_vram * 0.6) // approx_model_gb.get(MODEL_ARCH, 3)) * 4)\n    BATCH = per_gpu_batch * NUM_GPUS\nelse:\n    BATCH = -1  # AutoBatch: works for single-GPU, MPS, and CPU\n\nprint(f\"Model      : {MODEL_ARCH}\")\nprint(f\"Epochs     : {EPOCHS}\")\nprint(f\"Image size : {IMG_SIZE}\")\nprint(f\"Batch      : {BATCH if BATCH != -1 else 'auto'}\")\nprint(f\"Device(s)  : {DEVICE}\")\nprint(f\"Workers    : {WORKERS}\")\n\nmodel = YOLO(MODEL_ARCH)\n\ntrain_results = model.train(\n    data=str(DATA_YAML),\n    epochs=EPOCHS,\n    imgsz=IMG_SIZE,\n    batch=BATCH,\n    device=DEVICE,\n    workers=WORKERS,\n    project=str(PROJECT_ROOT / \"runs\"),\n    name=\"train_exp\",\n    exist_ok=True,\n)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T15:58:13.677643Z","iopub.execute_input":"2026-07-20T15:58:13.677953Z","iopub.status.idle":"2026-07-20T16:12:31.682631Z","shell.execute_reply.started":"2026-07-20T15:58:13.677926Z","shell.execute_reply":"2026-07-20T16:12:31.681595Z"}},"outputs":[{"name":"stdout","text":"Creating new Ultralytics Settings v0.0.6 file ✅ \nView Ultralytics Settings with 'yolo settings' or at '/root/.config/Ultralytics/settings.json'\nUpdate Settings with 'yolo settings key=value', i.e. 'yolo settings runs_dir=path/to/dir'. For help see https://docs.ultralytics.com/quickstart/#ultralytics-settings.\nModel      : yolov8m.pt\nEpochs     : 100\nImage size : 640\nBatch      : 8\nDevice(s)  : 0,1\nWorkers    : 4\n\u001b[KDownloading https://github.com/ultralytics/assets/releases/download/v8.4.0/yolov8m.pt to 'yolov8m.pt': 100% ━━━━━━━━━━━━ 49.7MB 190.9MB/s 0.3s0.2s<0.1s\nUltralytics 8.4.102 🚀 Python-3.12.13 torch-2.10.0+cu128 CUDA:0 (Tesla T4, 14912MiB)\n                                                        CUDA:1 (Tesla T4, 14912MiB)\n\u001b[34m\u001b[1mengine/trainer: \u001b[0magnostic_nms=False, amp=True, angle=1.0, augment=False, auto_augment=randaugment, batch=8, bgr=0.0, box=7.5, cache=False, cfg=None, classes=None, close_mosaic=10, cls=0.5, cls_pw=0.0, cls_remap=True, compile=False, conf=None, copy_paste=0.0, copy_paste_mode=flip, cos_lr=False, cutmix=0.0, data=/kaggle/working/yolo_dataset/data.yaml,