    "from ultralytics import YOLO\n",
    "\n",
    "# --- Auto-select model size from GPU memory available per device ---\n",
    "per_gpu_vram = (TOTAL_VRAM_GB / NUM_GPUS) if NUM_GPUS else 0\n",
    "if per_gpu_vram >= 16:\n",
    "    MODEL_ARCH = \"yolov8l.pt\"\n",
    "elif per_gpu_vram >= 8:\n",
    "    MODEL_ARCH = \"yolov8m.pt\"\n",
    "elif per_gpu_vram >= 4:\n",
    "    MODEL_ARCH = \"yolov8s.pt\"\n",
    "else:\n",
    "    MODEL_ARCH = \"yolov8n.pt\"   # safest default for CPU / MPS / low-VRAM GPUs\n",
    "\n",
    "# --- Auto-select epoch budget from dataset size (smaller dataset -> more epochs) ---\n",
    "if NUM_TRAIN_IMAGES < 1000:\n",
    "    EPOCHS = 100\n",
    "elif NUM_TRAIN_IMAGES < 5000:\n",
    "    EPOCHS = 150\n",
    "elif NUM_TRAIN_IMAGES < 20000:\n",
    "    EPOCHS = 100\n",
    "else:\n",
    "    EPOCHS = 50\n",
    "\n",
    "IMG_SIZE = 640\n",
    "WORKERS = os.cpu_count() or 4\n",
    "\n",
    "# --- Auto-select batch size ---\n",
    "# Ultralytics AutoBatch (batch=-1) picks the largest batch that fits in memory,\n",
    "# but it only supports a single device. With multiple GPUs we estimate a safe\n",
    "# per-GPU batch from measured VRAM and scale it by the number of GPUs instead.\n",
    "if NUM_GPUS > 1:\n",
    "    approx_model_gb = {\"yolov8n.pt\": 2, \"yolov8s.pt\": 3, \"yolov8m.pt\": 5, \"yolov8l.pt\": 7, \"yolov8x.pt\": 9}\n",
    "    per_gpu_batch = max(4, int((per_gpu_vram * 0.6) // approx_model_gb.get(MODEL_ARCH, 3)) * 4)\n",
    "    BATCH = per_gpu_batch * NUM_GPUS\n",
    "else:\n",
    "    BATCH = -1  # AutoBatch: works for single-GPU, MPS, and CPU\n",
    "\n",
    "print(f\"Model      : {MODEL_ARCH}\")\n",
    "print(f\"Epochs     : {EPOCHS}\")\n",
    "print(f\"Image size : {IMG_SIZE}\")\n",
    "print(f\"Batch      : {BATCH if BATCH != -1 else 'auto'}\")\n",
    "print(f\"Device(s)  : {DEVICE}\")\n",
    "print(f\"Workers    : {WORKERS}\")\n",
    "\n",
    "model = YOLO(MODEL_ARCH)\n",
